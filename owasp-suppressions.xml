<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">
    <!--
        OWASP Dependency Check 抑制文件
        
        此文件用于抑制已知的误报或已接受的风险。
        只有在以下情况下才应该添加抑制规则：
        1. 确认是误报
        2. 漏洞在非生产环境或测试依赖中
        3. 漏洞已被修复但依赖检查工具尚未更新
        4. 已接受的风险（需要文档说明原因）
        
        使用前请仔细评估每个抑制规则的必要性。
    -->
    
    <!-- 示例：抑制特定CVE（如果需要） -->
    <!--
    <suppress>
        <notes><![CDATA[
            抑制原因说明
        ]]></notes>
        <cve>CVE-YYYY-XXXXX</cve>
    </suppress>
    -->
    
    <!-- 示例：抑制特定依赖的特定CVE -->
    <!--
    <suppress>
        <notes><![CDATA[
            抑制原因说明
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/.*$</packageUrl>
        <cve>CVE-YYYY-XXXXX</cve>
    </suppress>
    -->
</suppressions>
