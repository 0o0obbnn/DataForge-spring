## DataForge (Supabase Postgres)
#
# 1) In Supabase Dashboard -> Project Settings -> Database:
#    Reset database password (or find existing) and set it below.
#
# 2) Then start backend:
#    cd data-forge-web && mvn spring-boot:run
#

# JDBC connection
DATASOURCE_URL=jdbc:postgresql://db.mxhjldkcgxniggkbbiye.supabase.co:5432/postgres?sslmode=require
DATASOURCE_USERNAME=postgres
DATASOURCE_PASSWORD=
DATASOURCE_DRIVER=org.postgresql.Driver

# Hibernate (optional; default is PostgreSQLDialect)
HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect

# Security
JWT_SECRET=

# Redis (optional but currently required by security/ratelimit features)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0
