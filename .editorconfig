# EditorConfig helps maintain consistent coding styles across IDEs and editors
# See https://editorconfig.org for more details

# Top-most EditorConfig file
root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Java files
[*.java]
indent_size = 2
max_line_length = 120

# XML (Maven pom.xml, etc.)
[*.xml]
indent_size = 2

# YAML (Spring configuration, etc.)
[*.{yml,yaml}]
indent_size = 2

# JSON
[*.json]
indent_size = 2

# Properties files
[*.properties]
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false

# SQL files
[*.sql]
indent_size = 2

# Shell scripts
[*.sh]
end_of_line = lf
indent_size = 2

# Windows batch scripts
[*.{bat,cmd}]
end_of_line = crlf

# Makefile (requires tabs)
[Makefile]
indent_style = tab
